# Database (required)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth (required for auth)
# Production (Vercel): set to your exact app URL, e.g. https://album-pulse.vercel.app (no trailing slash)
# Local: http://localhost:3000
NEXTAUTH_URL="https://your-app.vercel.app"
# Generate: openssl rand -base64 32. Must be the same across all Vercel instances.
NEXTAUTH_SECRET="generate-a-random-string-e-g-openssl-rand-base64-32"

# Google OAuth (required for "Sign in with Google")
# Create credentials: https://console.cloud.google.com/apis/credentials
# - Application type: Web application
# - Authorized redirect URIs (add BOTH for local + production):
#   https://album-pulse.vercel.app/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional
# LASTFM_API_KEY=
# MUSICBRAINZ_USER_AGENT="AlbumPulse/0.1"
# EMBEDDING_API_KEY=
# ADMIN_API_KEY=  (for admin routes in production)
