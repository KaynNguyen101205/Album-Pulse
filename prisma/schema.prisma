generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AlbumSource {
  MUSICBRAINZ
  LASTFM
  MANUAL
}

enum WeeklyDropStatus {
  ACTIVE
  EXPIRED
}

enum UserEventType {
  LIKE
  DISLIKE
  SAVE
  UNSAVE
  SKIP
  VIEW
}

enum NotInterestedReason {
  NOT_MY_GENRE
  DONT_LIKE_ARTIST
  ALREADY_KNOW_ALBUM
  TOO_SIMILAR_RECENT
  MOOD_MISMATCH
  OTHER
}

enum SuppressionTargetType {
  ARTIST
  TAG
  ALBUM
}

enum RecomputeRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum WeeklyMetricScope {
  USER
  GLOBAL
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  credential          UserCredential?
  favoriteAlbums      UserFavoriteAlbum[]
  ratings             AlbumRating[]
  reviews             AlbumReview[]
  events              UserEvent[]
  weeklyDrops         WeeklyDrop[]
  weeklyDropFeedback  WeeklyDropItemFeedback[]
  analyticsEvents     AnalyticsEvent[]
  preferenceProfile   UserPreferenceProfile?
  suppressions        UserPreferenceSuppression[]
  profileRecomputeRuns UserProfileRecomputeRun[]
  weeklyMetrics       WeeklyDropMetric[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model UserCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
}

model Artist {
  id        String   @id
  mbid      String?  @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albums Album[]
}

model Album {
  id                  String      @id
  mbid                String      @unique
  title               String
  artistId            String
  releaseYear         Int?
  coverUrl            String?
  description         String?
  source              AlbumSource @default(MUSICBRAINZ)
  popularityListeners Int?
  popularityPlaycount Int?
  popularityScore     Float?
  createdAt           DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  artist    Artist          @relation(fields: [artistId], references: [id], onDelete: Restrict)
  tags      AlbumTag[]
  embedding AlbumEmbedding?
  favorites UserFavoriteAlbum[]
  ratings   AlbumRating[]
  reviews   AlbumReview[]
  events    UserEvent[]
  dropItems WeeklyDropItem[]

  @@index([artistId])
  @@index([releaseYear])
}

model Tag {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albums AlbumTag[]
}

model AlbumTag {
  albumId   String
  tagId     String
  createdAt DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([albumId, tagId])
  @@index([tagId])
}

model AlbumEmbedding {
  id          String   @id
  albumId     String   @unique
  embedding   Unsupported("vector(384)")?
  modelVersion String
  createdAt   DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model UserFavoriteAlbum {
  id      String   @id
  userId  String
  albumId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model AlbumRating {
  id        String   @id
  userId    String
  albumId   String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model AlbumReview {
  id        String   @id
  userId    String
  albumId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model UserEvent {
  id        String        @id
  userId    String
  albumId   String?
  type      UserEventType
  metadata  Json?
  createdAt DateTime      @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album? @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([albumId])
}

model WeeklyDrop {
  id          String           @id
  userId      String
  weekStart   DateTime        @db.Date
  frozenUntil DateTime?       @db.Date
  generatedAt DateTime?
  status      WeeklyDropStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WeeklyDropItem[]

  @@unique([userId, weekStart])
  @@index([userId])
  @@index([weekStart])
}

model WeeklyDropItem {
  id          String   @id
  weeklyDropId String
  albumId     String
  rank        Int
  reason      Json?
  createdAt   DateTime @default(now())

  weeklyDrop WeeklyDrop @relation(fields: [weeklyDropId], references: [id], onDelete: Cascade)
  album      Album      @relation(fields: [albumId], references: [id], onDelete: Restrict)
  feedback   WeeklyDropItemFeedback[]

  @@unique([weeklyDropId, albumId])
  @@unique([weeklyDropId, rank])
  @@index([weeklyDropId])
  @@index([albumId])
}

model WeeklyDropItemFeedback {
  id               String   @id
  userId           String
  weeklyDropItemId String
  liked            Boolean?
  disliked         Boolean?
  skipped          Boolean?
  saved            Boolean?
  rating           Int?
  reviewText       String?
  alreadyListened  Boolean?
  listenedNotes    String?
  notInterestedReason    NotInterestedReason?
  notInterestedOtherText String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyDropItem WeeklyDropItem @relation(fields: [weeklyDropItemId], references: [id], onDelete: Cascade)

  @@unique([userId, weeklyDropItemId])
  @@index([userId, updatedAt])
  @@index([weeklyDropItemId])
}

model UserPreferenceProfile {
  id                    String   @id
  userId                String   @unique
  profileVersion        Int      @default(1)
  sourceWindowWeeks     Int      @default(12)
  artistWeights         Json
  tagWeights            Json
  albumWeights          Json
  metadata              Json?
  lastRecomputedAt      DateTime?
  lastRecomputedWeekStart DateTime? @db.Date
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastRecomputedWeekStart])
}

model UserPreferenceSuppression {
  id             String                @id
  userId         String
  targetType     SuppressionTargetType
  targetValue    String
  reason         NotInterestedReason?
  strength       Float                 @default(1)
  sourceWeekStart DateTime?           @db.Date
  expiresAt      DateTime
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetValue])
  @@index([userId, expiresAt])
  @@index([targetType, targetValue])
}

model UserProfileRecomputeRun {
  id                    String             @id
  userId                String
  weekStart             DateTime           @db.Date
  profileVersion        Int                @default(1)
  status                RecomputeRunStatus
  processedFeedbackCount Int               @default(0)
  generatedSuppressions Int                @default(0)
  message               String?
  startedAt             DateTime           @default(now())
  completedAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart, profileVersion])
  @@index([status, startedAt])
  @@index([userId, weekStart])
}

model WeeklyDropMetric {
  id           String           @id
  metricKey    String           @unique
  scope        WeeklyMetricScope
  userId       String?
  weekStart    DateTime         @db.Date
  weeklyDropId String?
  impressions  Int              @default(0)
  clicks       Int              @default(0)
  saves        Int              @default(0)
  ratingsCount Int              @default(0)
  ratingsSum   Int              @default(0)
  dislikes     Int              @default(0)
  skips        Int              @default(0)
  reviews      Int              @default(0)
  notInterested Int             @default(0)
  ctr          Float            @default(0)
  saveRate     Float            @default(0)
  avgRating    Float            @default(0)
  dislikeRate  Float            @default(0)
  skipRate     Float            @default(0)
  reviewRate   Float            @default(0)
  notInterestedRate Float       @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scope, weekStart])
  @@index([userId, weekStart])
}

model AnalyticsEvent {
  id               String   @id
  eventName        String
  userId           String
  weeklyDropId     String?
  weeklyDropItemId String?
  metadata         Json?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@index([weeklyDropId, createdAt])
  @@index([weeklyDropItemId, createdAt])
}

model ExternalCache {
  key         String   @id
  payloadJson Json
  source      String
  ttlSeconds  Int
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
  @@index([expiresAt])
}
