generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AlbumSource {
  MUSICBRAINZ
  LASTFM
  MANUAL
}

enum WeeklyDropStatus {
  ACTIVE
  EXPIRED
}

enum UserEventType {
  LIKE
  DISLIKE
  SAVE
  UNSAVE
  SKIP
  VIEW
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  credential          UserCredential?
  favoriteAlbums      UserFavoriteAlbum[]
  ratings             AlbumRating[]
  reviews             AlbumReview[]
  events              UserEvent[]
  weeklyDrops         WeeklyDrop[]
  weeklyDropFeedback  WeeklyDropItemFeedback[]
  analyticsEvents     AnalyticsEvent[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model UserCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
}

model Artist {
  id        String   @id
  mbid      String?  @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albums Album[]
}

model Album {
  id                  String      @id
  mbid                String      @unique
  title               String
  artistId            String
  releaseYear         Int?
  coverUrl            String?
  description         String?
  source              AlbumSource @default(MUSICBRAINZ)
  popularityListeners Int?
  popularityPlaycount Int?
  popularityScore     Float?
  createdAt           DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  artist    Artist          @relation(fields: [artistId], references: [id], onDelete: Restrict)
  tags      AlbumTag[]
  embedding AlbumEmbedding?
  favorites UserFavoriteAlbum[]
  ratings   AlbumRating[]
  reviews   AlbumReview[]
  events    UserEvent[]
  dropItems WeeklyDropItem[]

  @@index([artistId])
  @@index([releaseYear])
}

model Tag {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albums AlbumTag[]
}

model AlbumTag {
  albumId   String
  tagId     String
  createdAt DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([albumId, tagId])
  @@index([tagId])
}

model AlbumEmbedding {
  id          String   @id
  albumId     String   @unique
  embedding   Unsupported("vector(384)")?
  modelVersion String
  createdAt   DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model UserFavoriteAlbum {
  id      String   @id
  userId  String
  albumId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model AlbumRating {
  id        String   @id
  userId    String
  albumId   String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model AlbumReview {
  id        String   @id
  userId    String
  albumId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model UserEvent {
  id        String        @id
  userId    String
  albumId   String?
  type      UserEventType
  metadata  Json?
  createdAt DateTime      @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album? @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([albumId])
}

model WeeklyDrop {
  id          String           @id
  userId      String
  weekStart   DateTime        @db.Date
  frozenUntil DateTime?       @db.Date
  generatedAt DateTime?
  status      WeeklyDropStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WeeklyDropItem[]

  @@unique([userId, weekStart])
  @@index([userId])
  @@index([weekStart])
}

model WeeklyDropItem {
  id          String   @id
  weeklyDropId String
  albumId     String
  rank        Int
  reason      Json?
  createdAt   DateTime @default(now())

  weeklyDrop WeeklyDrop @relation(fields: [weeklyDropId], references: [id], onDelete: Cascade)
  album      Album      @relation(fields: [albumId], references: [id], onDelete: Restrict)
  feedback   WeeklyDropItemFeedback[]

  @@unique([weeklyDropId, albumId])
  @@unique([weeklyDropId, rank])
  @@index([weeklyDropId])
  @@index([albumId])
}

model WeeklyDropItemFeedback {
  id               String   @id
  userId           String
  weeklyDropItemId String
  liked            Boolean?
  disliked         Boolean?
  skipped          Boolean?
  saved            Boolean?
  rating           Int?
  reviewText       String?
  alreadyListened  Boolean?
  listenedNotes    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyDropItem WeeklyDropItem @relation(fields: [weeklyDropItemId], references: [id], onDelete: Cascade)

  @@unique([userId, weeklyDropItemId])
  @@index([userId, updatedAt])
  @@index([weeklyDropItemId])
}

model AnalyticsEvent {
  id               String   @id
  eventName        String
  userId           String
  weeklyDropId     String?
  weeklyDropItemId String?
  metadata         Json?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@index([weeklyDropId, createdAt])
  @@index([weeklyDropItemId, createdAt])
}

model ExternalCache {
  key         String   @id
  payloadJson Json
  source      String
  ttlSeconds  Int
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
  @@index([expiresAt])
}
