generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AlbumSource {
  MUSICBRAINZ
  LASTFM
  MANUAL
}

enum WeeklyDropStatus {
  ACTIVE
  EXPIRED
}

enum UserEventType {
  LIKE
  DISLIKE
  SAVE
  UNSAVE
  SKIP
  VIEW
}

model User {
  id        String   @id
  email     String?  @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions           Session[]
  favoriteAlbums     UserFavoriteAlbum[]
  ratings            AlbumRating[]
  reviews            AlbumReview[]
  events             UserEvent[]
  weeklyDrops        WeeklyDrop[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Artist {
  id        String   @id
  mbid      String?  @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albums Album[]
}

model Album {
  id                  String      @id
  mbid                String      @unique
  title               String
  artistId            String
  releaseYear         Int?
  coverUrl            String?
  description         String?
  source              AlbumSource @default(MUSICBRAINZ)
  popularityListeners Int?
  popularityPlaycount Int?
  popularityScore     Float?
  createdAt           DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  artist    Artist          @relation(fields: [artistId], references: [id], onDelete: Restrict)
  tags      AlbumTag[]
  embedding AlbumEmbedding?
  favorites UserFavoriteAlbum[]
  ratings   AlbumRating[]
  reviews   AlbumReview[]
  events    UserEvent[]
  dropItems WeeklyDropItem[]

  @@index([artistId])
  @@index([releaseYear])
}

model Tag {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albums AlbumTag[]
}

model AlbumTag {
  albumId   String
  tagId     String
  createdAt DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([albumId, tagId])
  @@index([tagId])
}

model AlbumEmbedding {
  id          String   @id
  albumId     String   @unique
  embedding   Unsupported("vector(384)")?
  modelVersion String
  createdAt   DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model UserFavoriteAlbum {
  id      String   @id
  userId  String
  albumId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model AlbumRating {
  id        String   @id
  userId    String
  albumId   String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model AlbumReview {
  id        String   @id
  userId    String
  albumId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model UserEvent {
  id        String        @id
  userId    String
  albumId   String?
  type      UserEventType
  metadata  Json?
  createdAt DateTime      @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album? @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([albumId])
}

model WeeklyDrop {
  id          String           @id
  userId      String
  weekStart   DateTime        @db.Date
  frozenUntil DateTime?       @db.Date
  generatedAt DateTime?
  status      WeeklyDropStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WeeklyDropItem[]

  @@unique([userId, weekStart])
  @@index([userId])
  @@index([weekStart])
}

model WeeklyDropItem {
  id          String   @id
  weeklyDropId String
  albumId     String
  rank        Int
  reason      Json?
  createdAt   DateTime @default(now())

  weeklyDrop WeeklyDrop @relation(fields: [weeklyDropId], references: [id], onDelete: Cascade)
  album      Album      @relation(fields: [albumId], references: [id], onDelete: Restrict)

  @@unique([weeklyDropId, albumId])
  @@unique([weeklyDropId, rank])
  @@index([weeklyDropId])
  @@index([albumId])
}

model ExternalCache {
  key         String   @id
  payloadJson Json
  source      String
  ttlSeconds  Int
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
  @@index([expiresAt])
}
