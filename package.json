{
  "name": "album-pulse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:verify": "npx tsx scripts/verify-crud.ts",
    "embed:albums": "npx tsx scripts/embed-albums.ts",
    "inspect:similar": "npx tsx scripts/inspect-similar.ts",
    "list:users": "npx tsx scripts/list-users.ts",
    "seed:test-user": "npx tsx scripts/seed-test-user.ts",
    "seed:more-albums": "npx tsx scripts/seed-more-albums.ts",
    "cron:weekly-drop": "npx tsx scripts/run-weekly-drop-cron.ts"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.0",
    "@prisma/client": "^5.10.0",
    "next": "14.0.4",
    "prisma": "^5.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "dotenv": "^16.4.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.0.4",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^4.0.18"
  }
}
